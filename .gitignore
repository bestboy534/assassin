# =========================================================
# SaaS Assassin MVP - root .gitignore
# =========================================================

# -----------------------------
# OS / Editor
# -----------------------------
.DS_Store
Thumbs.db
desktop.ini

.vscode/
.idea/
*.swp
*.swo
*.swn

# -----------------------------
# Env / Secrets
# -----------------------------
.env
.env.*
!.env.example

*.pem
*.key
*.crt
*.p12
*.pfx

# -----------------------------
# Logs
# -----------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

.Python
.python-version

.venv/
venv/
env/
ENV/

pip-wheel-metadata/
pip-log.txt

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# -----------------------------
# FastAPI / Backend Runtime
# -----------------------------
backend/.env
backend/.env.*
!backend/.env.example

backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal
backend/data/*.sqlite
backend/data/*.sqlite3

backend/logs/
backend/tmp/
backend/uploads/
backend/.cache/

# 保留后端静态配置 JSON
!backend/app/data/*.json

# -----------------------------
# Node / Frontend
# -----------------------------
node_modules/
frontend/node_modules/

frontend/.env
frontend/.env.*
!frontend/.env.example

frontend/dist/
frontend/build/
frontend/.vite/
frontend/.cache/
frontend/coverage/

# -----------------------------
# Package manager cache
# -----------------------------
.pnpm-store/
.npm/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# -----------------------------
# Generated JS files
# -----------------------------
# 如果你前端源码全部使用 TypeScript / TSX，可以启用下面规则。
# 注意：不要忽略配置文件，例如 vite.config.js、tailwind.config.js、postcss.config.js。
frontend/src/**/*.js
frontend/src/**/*.jsx
frontend/src/**/*.js.map
frontend/src/**/*.jsx.map

# 如果后端或脚本目录有生成 JS，也忽略
scripts/**/*.js
scripts/**/*.js.map

# -----------------------------
# Build artifacts
# -----------------------------
*.tsbuildinfo
*.map

# -----------------------------
# Database / Local data
# -----------------------------
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# 如果你希望保留空 data 目录，可以创建 .gitkeep
!backend/data/.gitkeep

# -----------------------------
# Uploaded / Sample sensitive files
# -----------------------------
uploads/
tmp/
temp/

# 注意：samples 目录如果只放 mock 数据可以上传。
# 如果里面放了真实账单，请取消注释下面两行：
# samples/
# !samples/.gitkeep

# -----------------------------
# Archives
# -----------------------------
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# -----------------------------
# Docker
# -----------------------------
.docker/
docker-compose.override.yml

# -----------------------------
# Misc
# -----------------------------
.cache/