# Runtime
APP_ENVIRONMENT=local
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI bill audit
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=gpt-4o-mini
USE_LLM=false
SAVE_RAW_BILLING_TEXT=false
MAX_INPUT_CHARS=30000

# Database: SQLite is supported for local/test only.
ENABLE_DATABASE=true
DATABASE_URL=sqlite+aiosqlite:///./data/saas_assassin.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false
AUTO_CREATE_SCHEMA=true

# Queue: use memory locally or redis in shared environments.
QUEUE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=assassin:jobs
WORKER_POLL_TIMEOUT_SECONDS=5

# Object storage: use local files locally or S3/MinIO in shared environments.
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=data/objects
STORAGE_SIGNING_SECRET=replace-outside-local-development
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=assassin
S3_SECRET_KEY=local_minio_only
S3_BUCKET_QUARANTINE=assassin-quarantine
S3_BUCKET_FILES=assassin-files
STORAGE_PRESIGN_EXPIRES_SECONDS=900
MAX_UPLOAD_BYTES=26214400
